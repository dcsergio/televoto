# Database Supabase PostgreSQL
# Usa URL DIRETTO (porta 5432) per migration Prisma.
# Usa eventualmente URL POOLED (porta 6543) per runtime server.
# Copia le connection string da: https://app.supabase.com -> Settings -> Database

# Diretto: necessario per `prisma migrate deploy`.
SUPABASE_DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.cowzpxxpvizcxamyizhg.supabase.co:5432/postgres"

# Pooled: opzionale per runtime (connessioni applicative).
SUPABASE_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"

# Override per Prisma CLI (migrate/resolve/db execute).
# Se la 5432 non e raggiungibile dalla tua rete, imposta qui la URL pooled per sbloccare i comandi CLI.
PRISMA_CLI_URL=""

# API Configuration (per sviluppo)
VITE_API_URL=http://localhost:3001

# Sicurezza admin (obbligatorio in produzione)
ADMIN_AUTH_SECRET="change-me-with-a-long-random-secret"

# Bootstrap credenziale root (usata se la tabella RootCredential è vuota)
ROOT_ADMIN_PASSWORD="ChangeMeRoot2026!"
