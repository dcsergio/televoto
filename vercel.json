{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "framework": "vite",
  "regions": ["iad1"],
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "{server/**,src/generated/prisma/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]"
    },
    {
      "source": "/admin",
      "destination": "/"
    },
    {
      "source": "/hof",
      "destination": "/"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
