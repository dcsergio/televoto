generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id           String      @id @default(cuid())
  name         String
  subtitle     String?
  active       Boolean     @default(true)
  votingClosed Boolean     @default(false)
  createdAt    DateTime    @default(now())
  candidates   Candidate[]
  judgeTokens  JudgeToken[]
}

model Candidate {
  id        String   @id @default(cuid())
  eventId   String
  number    Int
  name      String
  subtitle  String?
  color     String   @default("#6366f1")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes     Vote[]

  @@unique([eventId, number])
}

model JudgeToken {
  id           String   @id @default(cuid())
  eventId      String
  label        String?
  tokenHash    String   @unique
  tokenPreview String
  createdAt    DateTime @default(now())
  finalizedAt  DateTime?
  usedAt       DateTime?
  revokedAt    DateTime?
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@index([eventId])
}

model Vote {
  id            String       @id @default(cuid())
  candidateId   String
  deviceId      String?
  judgeTokenId  String?
  score         Int
  createdAt     DateTime     @default(now())
  candidate     Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  judgeToken    JudgeToken?  @relation(fields: [judgeTokenId], references: [id], onDelete: SetNull)

  @@unique([candidateId, deviceId])
  @@unique([candidateId, judgeTokenId])
}
